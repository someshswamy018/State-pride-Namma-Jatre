rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'Admin' ||
        (request.auth.token.email.lower().contains('someshswamy'))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Users can only create their own profile
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid;

      // Users can update their own profile
      allow update: if (isOwner(userId) || isAdmin())
        && isValidUser(incoming())
        && (isAdmin() || (
          incoming().uid == existing().uid
          && incoming().phoneNumber == existing().phoneNumber
          && incoming().createdAt == existing().createdAt
          && incoming().userType == existing().userType // Only admins can change userType
          && incoming().diff(existing()).affectedKeys().hasOnly([
            'fullName', 'email', 'age', 'gender', 'bloodGroup', 
            'village', 'address', 'profilePhotoUrl', 
            'idProofType', 'idProofUrl'
          ])
        ));
    }

    function isValidUser(data) {
      let requiredFields = [
        'uid', 'fullName', 'phoneNumber', 'age', 'gender', 
        'bloodGroup', 'village', 'userType', 'address', 
        'idProofType', 'createdAt'
      ];
      return data.keys().hasAll(requiredFields)
        && data.uid is string && data.uid.size() <= 128
        && data.fullName is string && data.fullName.size() <= 100
        && data.phoneNumber is string && data.phoneNumber.size() <= 20
        && data.age is int && data.age >= 0 && data.age <= 150
        && data.gender is string
        && data.bloodGroup is string
        && data.village is string
        && data.userType is string
        && data.address is string && data.address.size() <= 1000
        && data.idProofType is string
        && data.createdAt is timestamp;
    }

    // --- Live Schedule Collection ---
    match /live_schedule/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Lost & Found Collection ---
    match /lost_found/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.createdBy);
      allow delete: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.createdBy);
    }

    // --- Parking & Safety Collection ---
    match /parking_locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /safety_alerts/{alertId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Cultural Stories Collection ---
    match /cultural_stories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /emergency_messages/{id} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /emergency_contacts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /safety_guidelines/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /emergency_alerts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /crowd_status/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
